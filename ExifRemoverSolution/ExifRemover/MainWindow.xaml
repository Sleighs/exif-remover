<Window x:Class="ExifCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EXIF Cleaner" Height="620" Width="860"
        Background="#1e1e2e" Foreground="White">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <!-- Drop zone -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Output + actions -->
            <RowDefinition Height="Auto"/>
            <!-- Progress -->
        </Grid.RowDefinitions>

        <!-- Drop Zone -->
        <Border Grid.Row="0" BorderBrush="#585b70" BorderThickness="2"
                CornerRadius="8" AllowDrop="True"
                Drop="DropZone_Drop" DragOver="DropZone_DragOver"
                Background="#313244" Margin="0,0,0,12"
                x:Name="DropZone">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⬇ Drop images or folders here" FontSize="18"
                           HorizontalAlignment="Center" Foreground="#cdd6f4"/>
                <TextBlock Text="JPG, PNG, TIFF supported" FontSize="12"
                           HorizontalAlignment="Center" Foreground="#585b70" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- File list + metadata panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- File List -->
            <Border Background="#313244" CornerRadius="8" Margin="0,0,8,0">
                <DockPanel Margin="8">
                    <TextBlock DockPanel.Dock="Top" Text="Files" FontWeight="Bold"
                               Margin="0,0,0,8" Foreground="#cdd6f4"/>
                    <ListBox x:Name="FileListBox" Background="Transparent"
                             BorderThickness="0" Foreground="White"
                             SelectionChanged="FileListBox_SelectionChanged"/>
                </DockPanel>
            </Border>

            <!-- Metadata categories -->
            <Border Grid.Column="1" Background="#313244" CornerRadius="8">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Text="Metadata to Remove"
                               FontWeight="Bold" Margin="0,0,0,8" Foreground="#cdd6f4"/>
                    <TextBlock DockPanel.Dock="Top" x:Name="NoFileHint"
                               Text="Select a file to see its metadata"
                               Foreground="#585b70" FontSize="12" TextWrapping="Wrap"/>
                    <StackPanel x:Name="MetadataPanel" Visibility="Collapsed">
                        <CheckBox x:Name="ChkGps" Content="📍 GPS / Location"/>
                        <CheckBox x:Name="ChkCamera" Content="📷 Camera Info (make, model, lens)"/>
                        <CheckBox x:Name="ChkDatetime" Content="🕐 Date &amp; Time"/>
                        <CheckBox x:Name="ChkSoftware" Content="🖥 Software / Editor"/>
                        <CheckBox x:Name="ChkCopyright" Content="© Copyright / Author"/>
                        <CheckBox x:Name="ChkThumbnail" Content="🖼 Embedded Thumbnail"/>
                        <CheckBox x:Name="ChkOther" Content="⚙ Other EXIF Tags"/>
                        <Separator Margin="0,12" Background="#585b70"/>
                        <Button Content="Check All" Click="CheckAll_Click" Margin="0,0,0,4"/>
                        <Button Content="Uncheck All" Click="UncheckAll_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Output folder + process button -->
        <Grid Grid.Row="2" Margin="0,12,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="OutputFolderBox" Background="#313244" Foreground="White"
                     BorderBrush="#585b70" Padding="8,6" IsReadOnly="True"
                     Text="No output folder selected"/>
            <Button Grid.Column="1" Content="Browse…" Margin="8,0"
                    Click="BrowseOutput_Click"/>
            <Button Grid.Column="2" Content="▶ Clean Files" Background="#89b4fa"
                    Foreground="#1e1e2e" FontWeight="Bold" Click="CleanFiles_Click"/>
        </Grid>

        <!-- Progress -->
        <StackPanel Grid.Row="3">
            <ProgressBar x:Name="ProgressBar" Height="8" Background="#313244"
                         Foreground="#89b4fa" BorderThickness="0"/>
            <TextBlock x:Name="StatusText" Text="" Foreground="#a6adc8"
                       FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>
    </Grid>
</Window>